    <style>
        /* ── GitHub Markdown CSS — faithful to github.com rendering ── */

        :root {
            --color-fg-default: #1f2328;
            --color-fg-muted: #656d76;
            --color-fg-accent: #0969da;
            --color-canvas-default: #ffffff;
            --color-canvas-subtle: #f6f8fa;
            --color-border-default: #d1d9e0;
            --color-border-muted: hsla(210, 18%, 87%, 0.4);
            --color-neutral-muted: rgba(175, 184, 193, 0.2);
            --font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji";
            --font-mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
        }

        [data-theme="dark"] {
            --color-fg-default: #e6edf3;
            --color-fg-muted: #8b949e;
            --color-fg-accent: #58a6ff;
            --color-canvas-default: #0d1117;
            --color-canvas-subtle: #161b22;
            --color-border-default: #30363d;
            --color-border-muted: hsla(215, 8%, 47%, 0.4);
            --color-neutral-muted: rgba(110, 118, 129, 0.4);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            -webkit-text-size-adjust: 100%;
        }

        body {
            font-family: var(--font-body);
            font-size: 16px;
            line-height: 1.5;
            word-wrap: break-word;
            color: var(--color-fg-default);
            background-color: var(--color-canvas-default);
            -webkit-font-smoothing: antialiased;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        /* ── Container — matches GitHub readme width ── */

        .markdown-body {
            max-width: 1012px;
            margin: 0 auto;
            padding: 32px 28px 48px;
        }

        @media (min-width: 768px) {
            .markdown-body {
                padding: 48px 40px 64px;
            }
        }

        /* ── Headings ── */

        h1, h2, h3 {
            font-weight: 600;
            color: var(--color-fg-default);
            margin-top: 24px;
            margin-bottom: 16px;
            line-height: 1.25;
        }

        h1 {
            font-size: 2em;
            padding-bottom: 0.3em;
            border-bottom: 1px solid var(--color-border-default);
        }

        h2 {
            font-size: 1.5em;
            padding-bottom: 0.3em;
            border-bottom: 1px solid var(--color-border-default);
        }

        h3 {
            font-size: 1.25em;
        }

        h1:first-child,
        h2:first-child {
            margin-top: 0;
        }

        /* ── Paragraphs ── */

        p {
            margin-top: 0;
            margin-bottom: 16px;
            color: var(--color-fg-default);
        }

        /* ── Links ── */

        a {
            color: var(--color-fg-accent);
            text-decoration: underline;
        }

        a:hover {
            text-decoration: underline;
        }

        /* ── Lists ── */

        ul {
            padding-left: 0;
            margin-top: 0;
            margin-bottom: 16px;
            list-style: none;
        }

        li {
            margin-top: 0.25em;
        }

        li + li {
            margin-top: 0.25em;
        }

        /* ── Inline code ── */

        code {
            font-family: var(--font-mono);
            font-size: 85%;
            padding: 0.2em 0.4em;
            margin: 0;
            background-color: var(--color-neutral-muted);
            border-radius: 6px;
            white-space: break-spaces;
        }

        /* ── GitHub emoji images ── */

        .g-emoji {
            display: inline-block;
            width: 1em;
            height: 1em;
            vertical-align: -0.1em;
        }

        /* ── Theme toggle ── */

        .theme-toggle {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 100;
            width: 36px;
            height: 36px;
            border-radius: 6px;
            border: 1px solid var(--color-border-default);
            background: var(--color-canvas-subtle);
            color: var(--color-fg-muted);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: border-color 0.15s ease, background-color 0.15s ease;
        }

        .theme-toggle:hover {
            border-color: var(--color-fg-muted);
            color: var(--color-fg-default);
        }

        .theme-toggle svg {
            width: 18px;
            height: 18px;
            fill: currentColor;
        }

        .icon-sun { display: none; }
        .icon-moon { display: block; }
        [data-theme="dark"] .icon-sun { display: block; }
        [data-theme="dark"] .icon-moon { display: none; }

        /* ── Footer ── */

        footer {
            border-top: 1px solid var(--color-border-default);
            margin-top: 32px;
            padding-top: 16px;
        }

        footer p {
            font-size: 12px;
            color: var(--color-fg-muted);
            text-align: center;
            margin: 0;
        }

        /* ── Selection ── */

        ::selection {
            background: #0969da;
            color: #fff;
        }

        [data-theme="dark"] ::selection {
            background: #58a6ff;
            color: #0d1117;
        }

        /* ── Project list styling ── */

        a code {
            background: none;
            padding: 0;
            color: inherit;
        }

        .project-desc {
            color: var(--color-fg-muted);
        }
    </style>

    <script>
        (function() {
            var saved = localStorage.getItem('theme');
            var preferred = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', preferred);
        })();
    </script>
</head>
<body>

